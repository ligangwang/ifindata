# Public runtime configuration
NEXT_PUBLIC_APP_NAME=IFinData
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENVIRONMENT=development

# Firebase client SDK (baked into browser bundle at build time)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# Firebase Admin SDK (server-side only)
# On Cloud Run, Application Default Credentials (ADC) are used automatically.
# For local development, either set GOOGLE_APPLICATION_CREDENTIALS to the path of a
# service account JSON file, or set FIREBASE_SERVICE_ACCOUNT to the JSON content.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Backend integrations
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Twelve Data EOD price provider (server-side only)
TWELVE_DATA_API_KEY=your-twelve-data-api-key
# Optional override
# TWELVE_DATA_API_URL=https://api.twelvedata.com

# Internal scheduled jobs
INTERNAL_API_TOKEN=replace-with-a-long-random-token

# AI analyst jobs (server-side only)
AI_ANALYST_USER_ID=your-ai-analyst-firebase-uid
OPENAI_API_KEY=your-openai-api-key
# Optional override
# OPENAI_MODEL=gpt-5.4
# Optional USD-per-1M-token overrides for admin cost estimates.
# OPENAI_COST_RATES_JSON={"gpt-5.4":{"input":2.5,"cachedInput":0.25,"output":15}}

# SEC EDGAR access (server-side only)
# Include a descriptive app/contact string for SEC fair-access logs.
SEC_USER_AGENT=YouAnalyst company graph contact@example.com
# Company graph queue worker. Keep this low to avoid SEC/OpenAI spikes.
COMPANY_GRAPH_QUEUE_BATCH_SIZE=1
# Deployment scheduler vars are GitHub Environment variables, not app runtime vars.
# COMPANY_GRAPH_QUEUE_SCHEDULER_ENABLED=1
# COMPANY_GRAPH_QUEUE_SCHEDULER_JOB=company-graph-queue-production
# COMPANY_GRAPH_QUEUE_SCHEDULER_SCHEDULE=* * * * *
# COMPANY_GRAPH_QUEUE_SCHEDULER_LIMIT=1

# Google Cloud deployment
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
